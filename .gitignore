# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# database backups — contain the league's REAL data + the local prod
# connection string (backups/db_url.txt). NEVER commit. Keep off-machine
# copies per docs/BACKUP_RESTORE.md.
/backups/

# playwright (e2e)
/test-results/
/playwright-report/
/playwright/.cache/
/e2e/.auth/

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Sentry Config File
.env.sentry-build-plugin
